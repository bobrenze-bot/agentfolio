# AgentFolio Environment Configuration
# Copy this file to .env and customize for your deployment
# Version: 1.0.0

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
APP_ENV=production

# Debug mode (never enable in production)
DEBUG=false

# Secret key for JWT, sessions, and encryption
# Generate with: openssl rand -hex 32
SECRET_KEY=your-very-secure-secret-key-change-this-in-production-32bytes

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,agentfolio.io,*.agentfolio.io,api.agentfolio.io

# CORS origins (comma-separated)
CORS_ORIGINS=https://agentfolio.io,https://*.agentfolio.io,https://api.agentfolio.io

# =============================================================================
# DATABASE - PostgreSQL 15
# =============================================================================

POSTGRES_USER=agentfolio
POSTGRES_PASSWORD=secure-postgres-password-change-this
POSTGRES_DB=agentfolio
POSTGRES_PORT=5432

# =============================================================================
# CACHE & QUEUE - Redis 7
# =============================================================================

REDIS_PORT=6379

# =============================================================================
# ANALYTICS - ClickHouse
# =============================================================================

CLICKHOUSE_USER=agentfolio
CLICKHOUSE_PASSWORD=secure-clickhouse-password-change-this
CLICKHOUSE_DB=agentfolio_analytics
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# =============================================================================
# SERVICE PORTS
# =============================================================================

APP_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
FLOWER_PORT=5555
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# =============================================================================
# RATE LIMITING
# =============================================================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO
# Options: text, json
LOG_FORMAT=json

# =============================================================================
# CELERY WORKER
# =============================================================================

CELERY_CONCURRENCY=4

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# Flower basic auth (username:password)
FLOWER_BASIC_AUTH=admin:secure-flower-password

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=secure-grafana-password

# Grafana root URL
GRAFANA_ROOT_URL=https://grafana.agentfolio.io

# =============================================================================
# SSL/TLS CERTIFICATES
# =============================================================================

# SSL certificate paths (mounted to nginx/ssl/)
# For Let's Encrypt via Certbot, these will be:
# SSL_CERTIFICATE=/etc/nginx/ssl/live/agentfolio.io/fullchain.pem
# SSL_CERTIFICATE_KEY=/etc/nginx/ssl/live/agentfolio.io/privkey.pem

SSL_CERTIFICATE=/etc/nginx/ssl/cert.pem
SSL_CERTIFICATE_KEY=/etc/nginx/ssl/key.pem

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================

# GitHub API (for repository analysis)
GITHUB_TOKEN=your-github-token

# Moltbook API (for social metrics)
MOLTBOOK_API_KEY=your-moltbook-api-key

# Toku Agency API (for economic data)
TOKU_API_KEY=your-toku-api-key

# Cloudflare (for R2 storage)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
R2_BUCKET_NAME=agentfolio-assets

# Email (for notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
FROM_EMAIL=noreply@agentfolio.io

# =============================================================================
# SCORING & BUSINESS LOGIC
# =============================================================================

# Scoring update frequency (in hours)
SCORING_INTERVAL_HOURS=24

# Agent of the Week selection day (1=Monday, 7=Sunday)
AGENT_OF_WEEK_DAY=1
AGENT_OF_WEEK_HOUR=9

# Minimum scores for tiers
TIER_PIONEER_MIN=90
TIER_AUTONOMOUS_MIN=75
TIER_RECOGNIZED_MIN=60
TIER_ACTIVE_MIN=40
TIER_BECOMING_MIN=20

# =============================================================================
# SECURITY
# =============================================================================

# Max upload size (in MB)
MAX_UPLOAD_SIZE=10

# Session timeout (in minutes)
SESSION_TIMEOUT=60

# Password requirements
MIN_PASSWORD_LENGTH=12

# =============================================================================
# DEVELOPMENT ONLY (Do not use in production)
# =============================================================================

# Hot reload for development
ENABLE_RELOAD=false

# Test database (isolated from production)
TEST_DATABASE_URL=postgresql://agentfolio_test:test_password@localhost:5432/agentfolio_test
